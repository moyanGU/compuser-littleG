{
  "name": "compuser",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/run-minimal-tests.mjs && npm run windows-bridge:regression && npm run web:panel:module-regression",
    "capability:cli": "node dist/apps/cli/capability-cli.js",
    "compact:regression": "node dist/apps/cli/compact-regression.js",
    "dev:regression": "npm run build && node dist/apps/cli/dev-regression.js",
    "dev": "node dist/apps/cli/dev.js",
    "web:panel": "node dist/apps/web-panel/server.js",
    "web:panel:launcher": "node dist/apps/web-panel/ordinary-user-launcher.js",
    "web:panel:shell-smoke": "npm run build && node dist/apps/web-panel/panel-smoke.js",
    "web:panel:provider-smoke": "npm run build && node dist/apps/web-panel/provider-smoke.js",
    "web:panel:module-regression": "npm run build && node dist/apps/web-panel/server-options-regression.js && node dist/apps/web-panel/request-dispatcher-regression.js && node dist/apps/web-panel/session-control-flow-regression.js && node dist/apps/web-panel/system-product-flow-regression.js && node dist/apps/web-panel/template-launch-flow-regression.js",
    "product:smoke": "node dist/apps/web-panel/product-smoke.js",
    "product:verify": "npm run build && npm run product:smoke && npm run web:panel:provider-smoke",
    "discoverable:regression": "node dist/apps/cli/discoverable-tools-regression.js",
    "capability:regression": "node dist/apps/cli/capability-discovery-regression.js",
    "capability:cli:regression": "node dist/apps/cli/capability-cli-regression.js",
    "result-gc:daemon": "node dist/apps/cli/result-gc-daemon.js",
    "phase1:benchmark": "node dist/apps/cli/phase1-benchmark-regression.js",
    "phase4:chains": "node dist/apps/cli/phase4-chain-regression.js",
    "phase4:live-smoke": "node dist/apps/cli/phase4-live-smoke.js",
    "phase4:template-smoke": "node dist/apps/cli/phase4-template-smoke.js",
    "phase5:chains": "node dist/apps/cli/phase5-chain-regression.js",
    "phase5:live-smoke": "node dist/apps/cli/phase5-live-smoke.js",
    "phase5:scorecard": "node dist/apps/cli/phase5-scorecard.js",
    "phase5:template-smoke": "node dist/apps/cli/phase5-template-smoke.js",
    "recovery:regression": "node dist/apps/cli/recovery-regression.js",
    "routing:regression": "node dist/apps/cli/routing-state-regression.js",
    "provider:regression": "node dist/apps/cli/provider-regression.js",
    "provider:online": "node dist/apps/cli/provider-online-smoke.js",
    "windows:live-smoke": "node dist/apps/cli/windows-live-smoke.js",
    "windows:wechat-live-smoke": "node dist/apps/cli/windows-wechat-live-smoke.js",
    "windows:wechat-file-live-smoke": "node dist/apps/cli/windows-wechat-file-live-smoke.js",
    "windows-bridge:regression": "node dist/apps/cli/windows-bridge-regression.js",
    "windows:regression": "node dist/apps/cli/windows-phase1-regression.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
